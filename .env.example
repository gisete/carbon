# Carbon Environment Variables
# Copy this file to .env and update with your server-specific values

# Base URL for the application
# Set this to your server's IP address so TRMNL devices can fetch images
# Development: http://localhost:3000
# Production: http://YOUR_SERVER_IP:3000
BASE_URL=http://localhost:3000

# Home Assistant Integration
# Required for the Infrastructure screen to fetch UGREEN NAS metrics
# Example: http://homeassistant.local:8123
HA_BASE_URL=http://YOUR_HOME_ASSISTANT_URL:8123
# Long-lived access token from Home Assistant
# Generate at: Settings > Profile > Long-Lived Access Tokens
HA_ACCESS_TOKEN=YOUR_LONG_LIVED_ACCESS_TOKEN

# YouTube Analytics Screen
# Required for the YouTube channel stats screen
# API key: Google Cloud Console → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
# Your channel ID (found in YouTube Studio → Settings → Channel → Advanced)
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxx

# Sophie's Journey Screen — DeepL translation
# Required if journey-post.json contains only "raw" (Swedish) text
# Get a free key at: https://www.deepl.com/pro-api
DEEPL_API_KEY=your_deepl_api_key_here
